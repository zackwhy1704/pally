.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
build/
# pubspec.lock is COMMITTED (an app, not a package): the store artifact must build
# from a dependency set that exists in git, not from whatever `pub get` resolves at
# CI time. (Removing it here previously let a fresh resolve pull dio 5.10.0, whose
# new DioExceptionType.transformTimeout broke the switches → app wouldn't compile.)

# Web related
lib/generated_plugin_registrant.dart

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Secrets
.env
.env.local
.env.*.local
.kotlin/

# Secrets — never commit (Firebase config + Admin SDK private key)
android/app/google-services.json
/google-services.json
# Local eval/test fixtures + the Firebase admin key dumped under assets/documents
assets/documents/

# Golden test failure artifacts (regenerated on every failing run)
test/golden/failures/

# Xcode SwiftPM workspace state (Flutter-generated, not the .swiftpm/ dir)
**/xcshareddata/swiftpm/

# Claude Code agent worktrees (never commit)
.claude/worktrees/
